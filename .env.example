# =========================
# GLANet environment config
# =========================
# Copy this file to ".env" and adjust values for your machine.
# Paths can be absolute or relative to the project root.

# ------------------------------------------------------------------
# Core data/cache paths
# ------------------------------------------------------------------
# Root directory for shared outputs and generated npz files.
GLANET_DATA_ROOT=.

# Checkpoint directory (used by phase_pick.py and related scripts).
GLANET_CKPT_ROOT=checkpoints

# H5 dataset root directory.
GLANET_H5_ROOT=dataset

# Optional local CEED .h5 directory (empty means default behavior).
GLANET_CEED_LOCAL_DIR=

# Optional HuggingFace/datasets cache directory (empty means default cache).
GLANET_CACHE_DIR=

# ------------------------------------------------------------------
# Prediction/export paths
# ------------------------------------------------------------------
# Aligned TF prediction output npz path.
GLANET_TF_PRED_NPZ=phase_tf_predictions_aligned.npz

# phase_tf_pick.py output npz path.
GLANET_TF_OUT_NPZ=phase_tf_predictions_aligned.npz

# Optional shared sample export npz path.
GLANET_SHARED_SAMPLES_NPZ=shared_samples.npz

# ------------------------------------------------------------------
# External TF model paths (EQTransformer / EPick)
# ------------------------------------------------------------------
GLANET_EQT_WEIGHTS=checkpoints/eqt_best_weights.h5
GLANET_EQT_MODEL=checkpoints/eqt_model.keras
GLANET_EPICK_WEIGHTS=checkpoints/epick_best_weights.h5
GLANET_EPICK_MODEL=checkpoints/epick_model.keras

# ------------------------------------------------------------------
# Legacy/compatible output variable used by phase_core.py
# ------------------------------------------------------------------
# If set, training outputs are written under this directory.
PHASENET_OUTPUT_DIR=
